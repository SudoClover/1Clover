# Copy to `.env` (git-ignored) for local app config. PLACEHOLDER NAMES ONLY —
# never put a real secret in this file or anywhere in the repo (CLAUDE.md §4).

# ─── Public — safe to expose in the browser bundle (PUBLIC_ prefix) ──────────
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
PUBLIC_TURNSTILE_SITE_KEY="0xAAAA_turnstile_site_key"

# ─── Server-only — NEVER ship to the client; store in platform secret stores ─
# The Supabase SECRET key BYPASSES Row-Level Security. Treat its exposure as a
# full data breach. One named secret key per backend component (independently
# revocable). Use the new sb_secret_… format, never the legacy 10-year JWT keys.
SUPABASE_SECRET_KEY="sb_secret_xxx"

# Cloudflare R2 (object storage) — server-only
R2_ACCOUNT_ID="xxx"
R2_ACCESS_KEY_ID="xxx"
R2_SECRET_ACCESS_KEY="xxx"
R2_BUCKET="clover-media"

# Cloudflare API (deploy/CI only — belongs in the CI secret store, not here)
CLOUDFLARE_ACCOUNT_ID="xxx"
CLOUDFLARE_API_TOKEN="xxx"

# Turnstile secret — server-only (the token is verified server-side)
TURNSTILE_SECRET_KEY="0xBBBB_turnstile_secret_key"
